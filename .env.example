# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=helpdesk
DB_USER=root
DB_PASSWORD=

# Application
APP_URL=http://localhost:3000
APP_PORT=3000
APP_SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars

# SMTP (outgoing mail)
MAIL_SMTP_HOST=smtp.example.com
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=helpdesk@example.com
MAIL_SMTP_PASS=
MAIL_FROM_ADDRESS=helpdesk@example.com
MAIL_FROM_NAME=IT-Helpdesk

# IMAP (incoming mail)
MAIL_IMAP_HOST=imap.example.com
MAIL_IMAP_PORT=993
MAIL_IMAP_USER=helpdesk@example.com
MAIL_IMAP_PASS=

# Intervals
PING_INTERVAL_MINUTES=5
MAIL_POLL_INTERVAL_MINUTES=2

# Uploads
UPLOAD_MAX_SIZE_MB=20
UPLOAD_PATH=./uploads

# Network Check Method: icmp or http
NETWORK_CHECK_METHOD=http

# Microsoft OAuth (optional — leave empty to disable)
# Register an app at https://portal.azure.com → App registrations
# Redirect URI: https://your-domain.com/api/auth/microsoft/callback
MS_OAUTH_ENABLED=false
MS_OAUTH_CLIENT_ID=
MS_OAUTH_CLIENT_SECRET=
MS_OAUTH_TENANT_ID=common
MS_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/microsoft/callback
